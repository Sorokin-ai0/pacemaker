# Copy this file to server/.env for local development:
#   cp .env.example server/.env

# ── Supabase Postgres connection ────────────────────────────────────────────
# Use the SESSION POOLER connection string from your Supabase project:
#   Dashboard → Connect → ORMs/Prisma (or "Connection string" → Session pooler).
# It looks like:
#   postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres
# The session pooler (port 5432 on the *.pooler.supabase.com host) is IPv4 and
# behaves like a normal Postgres connection (works with Prisma + migrations).
# Avoid the "Direct connection" (db.<ref>.supabase.co:5432) — it is IPv6-only.
#
# Deploying to VERCEL (serverless)? Use the TRANSACTION pooler instead (port
# 6543) with ?pgbouncer=true&connection_limit=1 — each function invocation is
# its own process/connection, so this caps how many DB connections pile up.
# See the "Deployment — Vercel" section in README.md.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Secret used to sign JWT auth tokens — set a long random value in production
# (e.g. `openssl rand -base64 48`). Anyone with this can forge sessions.
JWT_SECRET="dev-secret-change-me"

# Port the API listens on (in production the single service serves API + client here)
PORT=3001

NODE_ENV=development

# Optional: seed a demo user on startup when the DB is empty (real-backend only)
SEED_DEMO=false

# ── AI coach (optional) ─────────────────────────────────────────────────────
# Required ONLY for the AI coach feature (daily brief, post-run recap, weekly
# check-in, plan reasoning, and the coach chat). Get a key from
# https://console.anthropic.com/ and paste it below. It is read server-side and
# never exposed to the browser. Leave it blank and the rest of the app runs
# normally — the coach surfaces just show a friendly "AI coach not configured"
# state instead of crashing.
ANTHROPIC_API_KEY=
