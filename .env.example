# Copy this file to server/.env for local development:
#   cp .env.example server/.env

# SQLite database file (path resolved relative to server/prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# Secret used to sign JWT auth tokens — set a long random value in production
JWT_SECRET="dev-secret-change-me"

# Port the API listens on (in production the single service serves API + client here)
PORT=3001

NODE_ENV=development

# Set to "true" to seed the demo user + demo plan on server start if the DB is empty
SEED_DEMO=false
